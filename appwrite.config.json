{
    "organizationId": "69f5ea1f13f0eaf1a651",
    "projectId": "6a3290500003e21b7fe1",
    "projectName": "Kenya Hub",
    "endpoint": "https://fra.cloud.appwrite.io/v1",
    "settings": {
        "services": {
            "account": true,
            "avatars": true,
            "databases": true,
            "locale": true,
            "health": true,
            "storage": true,
            "teams": true,
            "users": true,
            "sites": true,
            "functions": true,
            "graphql": true,
            "messaging": true
        },
        "protocols": {
            "rest": true,
            "graphql": true,
            "websocket": true
        },
        "auth": {
            "methods": {
                "jwt": true,
                "phone": true,
                "invites": true,
                "anonymous": true,
                "email-otp": true,
                "magic-url": true,
                "email-password": true
            },
            "security": {
                "duration": 31536000,
                "limit": 0,
                "sessionsLimit": 0,
                "passwordHistory": 0,
                "passwordDictionary": false,
                "personalDataCheck": false,
                "sessionAlerts": false,
                "mockNumbers": []
            }
        }
    },
    "tablesDB": [
        {
            "$id": "kenyahub-db",
            "name": "KenyaHub Database",
            "enabled": true
        }
    ],
    "tables": [
        {
            "$id": "blogs",
            "$permissions": [
                "read(\"any\")",
                "create(\"users\")",
                "update(\"users\")",
                "delete(\"users\")"
            ],
            "databaseId": "kenyahub-db",
            "name": "Blogs",
            "enabled": true,
            "rowSecurity": false,
            "columns": [
                {
                    "key": "title",
                    "type": "varchar",
                    "required": true,
                    "size": 255
                },
                {
                    "key": "slug",
                    "type": "varchar",
                    "required": true,
                    "size": 255
                },
                {
                    "key": "excerpt",
                    "type": "varchar",
                    "required": true,
                    "size": 500
                },
                {
                    "key": "author",
                    "type": "varchar",
                    "required": true,
                    "size": 255
                },
                {
                    "key": "content",
                    "type": "longtext",
                    "required": true
                },
                {
                    "key": "coverImage",
                    "type": "url",
                    "required": false
                },
                {
                    "key": "publishedAt",
                    "type": "varchar",
                    "required": true,
                    "size": 50
                },
                {
                    "key": "updatedAt",
                    "type": "varchar",
                    "required": false,
                    "size": 50
                },
                {
                    "key": "tags",
                    "type": "varchar",
                    "required": false,
                    "size": 50,
                    "array": true
                },
                {
                    "key": "readTime",
                    "type": "integer",
                    "required": true
                }
            ],
            "indexes": [
                {
                    "key": "idx_slug",
                    "type": "unique",
                    "status": "available",
                    "attributes": ["slug"]
                },
                {
                    "key": "idx_published_at",
                    "type": "key",
                    "status": "available",
                    "attributes": ["publishedAt"]
                }
            ]
        }
    ]
}